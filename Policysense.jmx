                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">{&quot;LineOfBusinessCode&quot;:${lob_code},&quot;ProductCode&quot;:${product_code},&quot;CalculationDate&quot;:&quot;2025-10-01T00:00:00.000Z&quot;,&quot;EffectiveDate&quot;:&quot;2025-10-01T00:00:00.000Z&quot;,&quot;ExpirationDate&quot;:&quot;2026-10-01T00:00:00.000Z&quot;,&quot;OriginalEffectiveDate&quot;:&quot;2025-10-01T00:00:00.000Z&quot;,&quot;SumInsured&quot;:0,&quot;SumInsuredAccumulationOfRisk&quot;:${sum_insured},&quot;SumInsuredTaxes&quot;:${sum_insured},&quot;AnnualPremium&quot;:323.04,&quot;ParticularData&quot;:&quot;{\&quot;Specie\&quot;:\&quot;Dog\&quot;,\&quot;Sex\&quot;:\&quot;Male\&quot;,\&quot;DateOfBirth\&quot;:\&quot;2012-12-16T00:00:00.000Z\&quot;,\&quot;Size\&quot;:\&quot;Medium\&quot;,\&quot;HasPedigree\&quot;:true,\&quot;Neutering\&quot;:true,\&quot;Dangerousness\&quot;:\&quot;Medium\&quot;,\&quot;PetValue\&quot;:30000,\&quot;PureBreed\&quot;:true}&quot;,&quot;InsuranceDuration&quot;:1,&quot;InsuranceDurationUnit&quot;:&quot;Years&quot;,&quot;OpportunityId&quot;:2179,&quot;ExecutionTime&quot;:1466,&quot;FirstAdditionalInformation&quot;:&quot;&quot;,&quot;SecondAdditionalInformation&quot;:&quot;&quot;,&quot;CalculatedCoverages&quot;:[{&quot;ClientRoleCode&quot;:1,&quot;CoverageCode&quot;:4,&quot;CoverageDescription&quot;:&quot;Asistencia por fallecimiento de la mascota&quot;,&quot;IsRequired&quot;:true,&quot;IsSelectedByDefault&quot;:true,&quot;IsSelected&quot;:true,&quot;SumInsured&quot;:2000,&quot;Rate&quot;:0.16152,&quot;TypeOfCoefficient&quot;:&quot;Multiplier&quot;,&quot;AnnualPremium&quot;:323.04},{&quot;ClientRoleCode&quot;:1,&quot;CoverageCode&quot;:1,&quot;CoverageDescription&quot;:&quot;Robo de la mascota&quot;,&quot;IsRequired&quot;:false,&quot;IsSelectedByDefault&quot;:false,&quot;IsSelected&quot;:false,&quot;SumInsured&quot;:30000,&quot;Rate&quot;:0.16152,&quot;TypeOfCoefficient&quot;:&quot;Multiplier&quot;,&quot;AnnualPremium&quot;:4845.6,&quot;VariationIDSelected&quot;:0,&quot;