uot;ModalPremiumNetOfTaxes&quot;:113.064,&quot;GrossModalPremium&quot;:159.9048,&quot;GrossPremiumByBillItems&quot;:[{&quot;BillingItemCode&quot;:1,&quot;BillingItemDescription&quot;:&quot;Prima total&quot;,&quot;AnnualBillingAmount&quot;:323.04,&quot;ModalBillingAmount&quot;:113.064},{&quot;BillingItemCode&quot;:2,&quot;BillingItemDescription&quot;:&quot;Impuestos&quot;,&quot;AnnualBillingAmount&quot;:46.8408,&quot;ModalBillingAmount&quot;:46.8408}]}],&quot;ExtrapremiumDiscountTaxRisks&quot;:[{&quot;ExtrapremiumDiscountTaxCode&quot;:1,&quot;ApplicationOrder&quot;:10,&quot;Description&quot;:&quot;Impuesto al valor agregado&quot;,&quot;IsRequired&quot;:true,&quot;IsSelectedByDefault&quot;:true,&quot;IsSelected&quot;:true}],&quot;ReturnValueOptionList&quot;:true}</stringProp>
